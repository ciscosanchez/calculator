generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum CalculatorType {
  FINAL_MILE
  HOTEL_INSTALLATION
  PALLET_HANDLING
  WAREHOUSE_STORAGE
}

enum BusinessType {
  COMMERCIAL
  RESIDENTIAL
  INDUSTRIAL
}

// ── Multi-tenancy ─────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  locations Location[]
  quotes    Quote[]

  @@index([slug])
}

model Location {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  city      String?
  state     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users        User[]
  costProfiles CostProfile[]

  @@index([tenantId])
}

// ── Users & Auth ──────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  passwordHash   String?
  role           Role      @default(USER)
  tenantId       String?
  locationId     String?
  isActive       Boolean   @default(true)
  emailVerified  DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant   Tenant?   @relation(fields: [tenantId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])
  quotes   Quote[]
  sessions Session[]
  accounts Account[]

  @@index([tenantId])
  @@index([email])
}

// NextAuth required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Cost Profiles ─────────────────────────────────────────────────────────────

model CostProfile {
  id          String   @id @default(cuid())
  locationId  String
  name        String
  description String?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  location    Location         @relation(fields: [locationId], references: [id])
  entries     CostEntry[]

  @@index([locationId])
}

model CostEntry {
  id            String   @id @default(cuid())
  costProfileId String
  category      String   // e.g. "LABOR", "EQUIPMENT", "FUEL", "OVERHEAD"
  label         String
  unit          String?  // e.g. "per hour", "per mile", "per pallet"
  rate          Decimal  @db.Decimal(10, 4)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  costProfile CostProfile @relation(fields: [costProfileId], references: [id], onDelete: Cascade)

  @@index([costProfileId])
}

// ── Quotes ────────────────────────────────────────────────────────────────────

model Quote {
  id              String         @id @default(cuid())
  userId          String
  tenantId        String?
  calculatorType  CalculatorType
  businessType    BusinessType   @default(COMMERCIAL)
  projectName     String
  customerName    String?
  customerEmail   String?
  inputs          Json           // All calculator-specific inputs stored as JSON
  totalCost       Decimal?       @db.Decimal(12, 2)
  revenue         Decimal?       @db.Decimal(12, 2)
  margin          Decimal?       @db.Decimal(5, 2) // percentage e.g. 21.50
  status          QuoteStatus    @default(DRAFT)
  notes           String?        @db.Text
  shareToken      String?        @unique
  shareExpiresAt  DateTime?
  netsuiteId      String?        // NetSuite Sales Order ID after export
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user      User           @relation(fields: [userId], references: [id])
  tenant    Tenant?        @relation(fields: [tenantId], references: [id])
  lineItems QuoteLineItem[]
  history   QuoteHistory[]

  @@index([userId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  quoteId     String
  category    String
  label       String
  quantity    Decimal @db.Decimal(10, 2)
  unit        String?
  unitCost    Decimal @db.Decimal(10, 4)
  totalCost   Decimal @db.Decimal(12, 2)
  notes       String?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model QuoteHistory {
  id        String   @id @default(cuid())
  quoteId   String
  action    String   // e.g. "CREATED", "UPDATED", "STATUS_CHANGED", "EXPORTED"
  changedBy String?
  diff      Json?    // What changed
  createdAt DateTime @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

// ── Audit ─────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  tenantId  String?
  action    String
  resource  String
  resourceId String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([createdAt])
}
